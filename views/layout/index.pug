doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(http-equiv="X-UA-Compatible", content="ie=edge")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title BienesRaices | #{pagina}
    //- Los estilos de librerias se cargan primero.
    //- app.css queda despues para que las utilidades de Tailwind tengan prioridad.
    block styles
    link(rel="stylesheet", href="/css/app.css")
  body(class="flex min-h-screen flex-col bg-slate-50 text-slate-900 antialiased")

    //- Layout publico para autenticacion y paginas informativas.
    main(class="mx-auto w-full max-w-7xl flex-1 px-4 py-8 sm:px-6 lg:px-8")
      block contenido

    include footer

    block scripts
