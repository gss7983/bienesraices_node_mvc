extends ./layout/app

//- Reutiliza la misma tarjeta del inicio para mantener un diseño consistente.
include ./propiedades/partials/card

block contenido
  section(aria-labelledby="titulo-categoria")
    a(
      class="inline-flex min-h-10 items-center justify-center rounded-full border border-emerald-700 px-4 py-2 text-sm font-bold text-emerald-700 transition hover:bg-emerald-50 hover:text-emerald-800 focus:outline-none focus:ring-4 focus:ring-emerald-100"
      href="/#categorias-inicio"
    ) ← Volver a categorías

    header(class="mt-7 border-b border-slate-200 pb-7")
      p(class="text-sm font-bold uppercase text-emerald-700") Catálogo de propiedades
      h1#titulo-categoria(class="mt-2 break-words text-3xl font-extrabold text-slate-900 sm:text-4xl")= pagina

      if categoria
        p(class="mt-3 text-sm leading-6 text-slate-600 sm:text-base")
          if totalPropiedades === 1
            | Encontramos 1 propiedad publicada en esta categoría.
          else
            | Encontramos #{totalPropiedades} propiedades publicadas en esta categoría.

    if error
      div(class="mt-7 rounded-lg border border-red-200 bg-red-50 px-5 py-4" role="alert")
        p(class="text-sm font-semibold text-red-700")= error

    if propiedades && propiedades.length
      div#listado-categoria(class="mt-7 grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3")
        each propiedad in propiedades
          +cardPropiedad(propiedad, "categorias-inicio")

      if paginacion && paginacion.totalPaginas > 1
        nav(
          class="mt-10 flex flex-wrap items-center justify-center gap-2"
          aria-label="Paginación de propiedades"
        )
          if paginacion.paginaActual > 1
            a(
              class="inline-flex min-h-10 items-center justify-center rounded-full border border-emerald-700 px-4 py-2 text-sm font-bold text-emerald-700 transition hover:bg-emerald-50 focus:outline-none focus:ring-4 focus:ring-emerald-100"
              href=`/categorias/${categoria.id}?pagina=${paginacion.paginaActual - 1}#listado-categoria`
              rel="prev"
            ) ← Anterior

          each paginaNumero in paginacion.rango
            if paginaNumero === "..."
              span(class="inline-flex h-10 min-w-10 items-center justify-center text-sm font-bold text-slate-400" aria-hidden="true") …
            else if paginaNumero === paginacion.paginaActual
              span(
                class="inline-flex h-10 min-w-10 items-center justify-center rounded-full bg-emerald-700 px-3 text-sm font-bold text-white"
                aria-current="page"
              )= paginaNumero
            else
              a(
                class="inline-flex h-10 min-w-10 items-center justify-center rounded-full border border-slate-300 bg-white px-3 text-sm font-bold text-slate-700 transition hover:border-emerald-500 hover:bg-emerald-50 hover:text-emerald-800 focus:outline-none focus:ring-4 focus:ring-emerald-100"
                href=`/categorias/${categoria.id}?pagina=${paginaNumero}#listado-categoria`
                aria-label=`Ir a la página ${paginaNumero}`
              )= paginaNumero

          if paginacion.paginaActual < paginacion.totalPaginas
            a(
              class="inline-flex min-h-10 items-center justify-center rounded-full bg-emerald-700 px-4 py-2 text-sm font-bold text-white transition hover:bg-emerald-800 focus:outline-none focus:ring-4 focus:ring-emerald-200"
              href=`/categorias/${categoria.id}?pagina=${paginacion.paginaActual + 1}#listado-categoria`
              rel="next"
            ) Siguiente →
    else
      unless error
        div(class="mt-7 rounded-lg border border-dashed border-slate-300 bg-white px-6 py-12 text-center")
          h2(class="text-xl font-extrabold text-slate-900") No hay resultados
          p(class="mx-auto mt-2 max-w-lg text-sm leading-6 text-slate-500") Todavía no existen propiedades publicadas en esta categoría.
          a(
            class="mt-6 inline-flex min-h-11 items-center justify-center rounded-full bg-emerald-700 px-5 py-3 text-sm font-bold text-white transition hover:bg-emerald-800 focus:outline-none focus:ring-4 focus:ring-emerald-200"
            href="/#categorias-inicio"
          ) Explorar otras categorías
