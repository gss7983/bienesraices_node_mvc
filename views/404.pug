extends ./layout/app

block contenido
  //- Página pública para direcciones o categorías inexistentes.
  section(
    class="grid min-h-[55vh] place-items-center py-8 sm:py-12"
    aria-labelledby="titulo-error"
  )
    div(class="w-full max-w-3xl text-center")
      p(class="text-7xl font-extrabold text-emerald-700 sm:text-8xl" aria-hidden="true") 404
      p(class="mt-5 text-sm font-bold uppercase text-emerald-700") Dirección no encontrada
      h1#titulo-error(class="mt-2 text-3xl font-extrabold text-slate-900 sm:text-4xl")= pagina
      p(class="mx-auto mt-4 max-w-xl text-sm leading-7 text-slate-600 sm:text-base")= mensaje

      nav(
        class="mt-8 flex flex-col items-stretch justify-center gap-3 sm:flex-row sm:items-center"
        aria-label="Opciones para continuar"
      )
        a(
          class="inline-flex min-h-11 items-center justify-center rounded-full bg-emerald-700 px-6 py-3 text-sm font-bold text-white shadow-sm transition hover:bg-emerald-800 hover:shadow-md focus:outline-none focus:ring-4 focus:ring-emerald-200"
          href="/"
        ) Ir a la página de inicio

        a(
          class="inline-flex min-h-11 items-center justify-center rounded-full border border-emerald-700 px-6 py-3 text-sm font-bold text-emerald-700 transition hover:bg-emerald-50 hover:text-emerald-800 focus:outline-none focus:ring-4 focus:ring-emerald-100"
          href="/#categorias-inicio"
        ) Explorar categorías

      p(class="mt-8 text-xs font-semibold text-slate-400") Error 404 · El servidor no encontró el recurso solicitado.
    
