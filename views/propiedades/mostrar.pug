extends ../layout/app

block contenido
  //- Permite regresar directamente al mapa publico conservando un recorrido claro.
  nav(class="mb-6" aria-label="Navegación de la propiedad")
    a(
      class="inline-flex min-h-10 items-center justify-center rounded-full border border-emerald-700 px-4 py-2 text-sm font-bold text-emerald-700 transition hover:bg-emerald-50 hover:text-emerald-800 focus:outline-none focus:ring-4 focus:ring-emerald-100"
      href=volverA || "/#mapa-inicio"
    ) ← Volver a propiedades

  if propiedad
    //- Encabezado del anuncio.
    section(class="space-y-6")
      div(class="flex flex-col gap-4 border-b border-slate-200 pb-6 sm:flex-row sm:items-end sm:justify-between")
        div(class="min-w-0")
          p(class="text-sm font-bold text-emerald-700")= propiedad.categoria && propiedad.categoria.nombre ? propiedad.categoria.nombre : "Propiedad"
          h1(class="mt-2 break-words text-3xl font-extrabold text-slate-900 sm:text-4xl lg:text-5xl")= propiedad.titulo
          if propiedad.calle
            p(class="mt-3 break-words text-sm leading-6 text-slate-600 sm:text-base")= propiedad.calle

        p(class="shrink-0 text-2xl font-extrabold text-emerald-700 sm:text-3xl")= propiedad.precio && propiedad.precio.precio ? propiedad.precio.precio : "Precio no disponible"

      //- En escritorio la imagen ocupa 2/3 y el mapa 1/3.
      //- En pantallas pequeñas ambos elementos se apilan y conservan su altura.
      section(
        class="grid gap-5 lg:grid-cols-[minmax(0,2fr)_minmax(18rem,1fr)]"
        aria-label="Imagen y ubicación de la propiedad"
      )
        figure(class="aspect-[16/10] overflow-hidden rounded-lg bg-slate-100 shadow-sm sm:aspect-[16/9] lg:aspect-auto lg:min-h-[30rem]")
          img(
            class="h-full w-full object-cover"
            src=`/uploads/${propiedad.imagen}`
            alt=`Imagen de ${propiedad.titulo}`
          )

        div(class="space-y-2")
          h2(class="text-lg font-extrabold text-slate-900") Ubicación
          p(class="text-sm leading-6 text-slate-600") Selecciona el marcador para consultar la dirección.
          div#mapa(
            class="h-80 overflow-hidden rounded-lg border border-slate-200 bg-slate-100 shadow-sm sm:h-96 lg:h-[calc(100%-4.5rem)] lg:min-h-[25.5rem]"
            data-lat=propiedad.lat
            data-lng=propiedad.lng
            data-calle=propiedad.calle
            aria-label=`Mapa de la ubicación de ${propiedad.titulo}`
          )

      div(class=esVendedor ? "grid gap-8" : "grid gap-8 lg:grid-cols-[minmax(0,2fr)_minmax(17rem,1fr)]")
        article(class="min-w-0 space-y-7")
          section(aria-labelledby="caracteristicas")
            h2#caracteristicas(class="text-xl font-extrabold text-slate-900 sm:text-2xl") Características
            dl(class="mt-4 grid grid-cols-3 divide-x divide-slate-200 rounded-lg border border-slate-200 bg-white py-5 shadow-sm")
              div(class="min-w-0 px-2 text-center sm:px-5")
                dt(class="break-words text-xs font-semibold text-slate-500 sm:text-sm") Habitaciones
                dd(class="mt-2 text-xl font-extrabold text-slate-900 sm:text-2xl")= propiedad.habitaciones
              div(class="min-w-0 px-2 text-center sm:px-5")
                dt(class="break-words text-xs font-semibold text-slate-500 sm:text-sm") Estacionamiento
                dd(class="mt-2 text-xl font-extrabold text-slate-900 sm:text-2xl")= propiedad.estacionamiento
              div(class="min-w-0 px-2 text-center sm:px-5")
                dt(class="break-words text-xs font-semibold text-slate-500 sm:text-sm") WC
                dd(class="mt-2 text-xl font-extrabold text-slate-900 sm:text-2xl")= propiedad.wc

          section(class="border-t border-slate-200 pt-7" aria-labelledby="descripcion")
            h2#descripcion(class="text-xl font-extrabold text-slate-900 sm:text-2xl") Descripción
            p(class="mt-4 whitespace-pre-line break-words text-base leading-8 text-slate-600")= propiedad.descripcion
        //- El vendedor no necesita un formulario para contactarse a si mismo.
        if !esVendedor
          aside(class="self-start rounded-lg border border-emerald-200 bg-emerald-50 p-6")
            p(class="text-sm font-bold uppercase text-emerald-700") Propiedad publicada por
            p(class="mt-2 break-words text-xl font-extrabold text-slate-900")= propiedad.usuario && propiedad.usuario.nombre ? propiedad.usuario.nombre : "Anunciante"

            if mensajeEnviado
              div(class="mt-4 rounded-lg border border-emerald-300 bg-white px-4 py-4" role="status")
                p(class="text-sm font-bold text-emerald-800") Mensaje enviado correctamente.
                p(class="mt-1 text-sm leading-6 text-slate-600") El vendedor podrá consultarlo desde la bandeja de mensajes que agregaremos en el siguiente módulo.

              div(class="mt-4 grid gap-2")
                a(
                  class="inline-flex min-h-10 items-center justify-center rounded-full border border-emerald-700 px-4 py-2 text-sm font-bold text-emerald-700 transition hover:bg-emerald-50 focus:outline-none focus:ring-4 focus:ring-emerald-100"
                  href="/#categorias-inicio"
                ) Seguir explorando
                form(method="POST" action="/auth/logout")
                  input(type="hidden" name="_csrf" value=csrfToken)
                  button(
                    type="submit"
                    class="inline-flex min-h-10 w-full items-center justify-center rounded-full border border-slate-300 px-4 py-2 text-sm font-bold text-slate-600 transition hover:border-red-300 hover:bg-red-50 hover:text-red-700 focus:outline-none focus:ring-4 focus:ring-red-100"
                  ) Cerrar sesión

            else if usuarioAutenticado
              //- Los errores aparecen antes del formulario.
              if erroresMensaje && erroresMensaje.length
                div(class="mt-5 rounded-lg border border-red-200 bg-red-50 px-4 py-3" role="alert")
                  p(class="text-sm font-bold text-red-800") Revisa tu mensaje:
                  ul(class="mt-2 space-y-1")
                    each errorMensaje in erroresMensaje
                      li(class="text-sm text-red-700")= errorMensaje.msg

              form(
                method="POST"
                action=`/propiedad/${propiedad.id}`
                class=(erroresMensaje && erroresMensaje.length ? "mt-3 space-y-4" : "mt-5 space-y-4")
                novalidate
              )
                input(type="hidden" name="_csrf" value=csrfToken)
                input(type="hidden" name="origen" value=(volverA || "/#mapa-inicio").replace("/#", ""))

                div
                  label(for="mensaje" class="mb-2 block text-sm font-bold text-slate-700") Mensaje
                  textarea(
                    id="mensaje"
                    name="mensaje"
                    rows="5"
                    aria-describedby="ayuda-mensaje"
                    class="w-full resize-none rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm leading-6 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-emerald-600 focus:ring-4 focus:ring-emerald-100"
                    placeholder="Escribe tu mensaje para el vendedor"
                  )= mensajeEscrito || ""
                  p#ayuda-mensaje(class="mt-2 text-xs text-slate-500") Máximo 200 caracteres.

                button(
                  type="submit"
                  class="inline-flex min-h-11 w-full cursor-pointer items-center justify-center rounded-full bg-emerald-700 px-5 py-3 text-sm font-bold text-white transition hover:bg-emerald-800 focus:outline-none focus:ring-4 focus:ring-emerald-200"
                ) Enviar mensaje
            else
              p(class="mt-4 text-sm leading-6 text-slate-600") Inicia sesión o crea una cuenta para contactar al vendedor.
              - const origenRetorno = (volverA || "/#mapa-inicio").replace("/#", "")
              - const rutaRetorno = `/propiedad/${propiedad.id}?origen=${origenRetorno}`
              div(class="mt-5 grid gap-2 sm:grid-cols-2 lg:grid-cols-1")
                a(
                  class="inline-flex min-h-11 items-center justify-center rounded-full bg-emerald-700 px-5 py-3 text-sm font-bold text-white transition hover:bg-emerald-800 focus:outline-none focus:ring-4 focus:ring-emerald-200"
                  href=`/auth/login?returnTo=${encodeURIComponent(rutaRetorno)}`
                ) Iniciar sesión
                a(
                  class="inline-flex min-h-11 items-center justify-center rounded-full border border-emerald-700 px-5 py-3 text-sm font-bold text-emerald-700 transition hover:bg-white focus:outline-none focus:ring-4 focus:ring-emerald-100"
                  href=`/auth/registro?returnTo=${encodeURIComponent(rutaRetorno)}`
                ) Crear cuenta
  else
    //- Respuesta clara para ids inexistentes o anuncios que no están publicados.
    section(class="grid min-h-[55vh] place-items-center")
      div(class="w-full max-w-2xl rounded-lg border border-slate-200 bg-white px-6 py-12 text-center shadow-sm sm:px-10")
        p(class="text-sm font-bold uppercase text-emerald-700") BienesRaices
        h1(class="mt-3 text-3xl font-extrabold text-slate-900") Propiedad no disponible
        p(class="mx-auto mt-4 max-w-lg text-sm leading-6 text-slate-600")= error || "La propiedad no existe, fue retirada o todavía no se encuentra publicada."
        a(
          class="mt-7 inline-flex min-h-11 items-center justify-center rounded-full bg-emerald-700 px-5 py-3 text-sm font-bold text-white transition hover:bg-emerald-800 focus:outline-none focus:ring-4 focus:ring-emerald-200"
          href=volverA || "/#mapa-inicio"
        ) Volver a propiedades

block styles
  //- Utiliza la misma hoja local que el mapa de la pagina de inicio.
  link(rel="stylesheet" href="/css/leaflet.css")

block scripts
  script(src="/js/mostrarMapa.js" defer)
