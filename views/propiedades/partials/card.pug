//- Tarjeta reutilizable. "origen" permite regresar al listado desde el detalle.
mixin cardPropiedad(propiedad, origen)
  article(
    class="group flex min-w-0 flex-col overflow-hidden rounded-lg border border-slate-200 bg-white shadow-md transition duration-300 ease-out hover:-translate-y-1 hover:border-emerald-300 hover:shadow-xl focus-within:-translate-y-1 focus-within:border-emerald-400 focus-within:shadow-xl"
  )
    a(
      class="block aspect-[16/10] overflow-hidden bg-slate-100 focus:outline-none focus:ring-4 focus:ring-inset focus:ring-emerald-200"
      href=`/propiedad/${propiedad.id}?origen=${origen}`
      aria-label=`Ver ${propiedad.titulo}`
    )
      img(
        class="h-full w-full object-cover transition duration-500 ease-out group-hover:scale-105"
        src=`/uploads/${propiedad.imagen}`
        alt=`Imagen de ${propiedad.titulo}`
        loading="lazy"
      )

    div(class="flex flex-1 flex-col p-5")
      if propiedad.precio && propiedad.precio.precio
        p(class="text-sm font-extrabold text-emerald-700")= propiedad.precio.precio

      h3(class="mt-2 break-words text-xl font-extrabold text-slate-900")
        a(
          class="transition hover:text-emerald-700 focus:outline-none focus:text-emerald-700"
          href=`/propiedad/${propiedad.id}?origen=${origen}`
        )= propiedad.titulo

      if propiedad.calle
        p(class="mt-2 line-clamp-2 break-words text-sm leading-6 text-slate-500")= propiedad.calle

      dl(class="mt-5 grid grid-cols-3 divide-x divide-slate-200 border-y border-slate-200 py-3 text-center")
        div(class="min-w-0 px-1")
          dt(class="text-xs font-semibold text-slate-500") Habitaciones
          dd(class="mt-1 text-base font-extrabold text-slate-900")= propiedad.habitaciones
        div(class="min-w-0 px-1")
          dt(class="text-xs font-semibold text-slate-500") Estac.
          dd(class="mt-1 text-base font-extrabold text-slate-900")= propiedad.estacionamiento
        div(class="min-w-0 px-1")
          dt(class="text-xs font-semibold text-slate-500") WC
          dd(class="mt-1 text-base font-extrabold text-slate-900")= propiedad.wc

      a(
        class="mt-5 inline-flex min-h-11 items-center justify-center rounded-full bg-emerald-700 px-5 py-3 text-sm font-bold text-white transition hover:bg-emerald-800 focus:outline-none focus:ring-4 focus:ring-emerald-200"
        href=`/propiedad/${propiedad.id}?origen=${origen}`
      ) Ver propiedad
