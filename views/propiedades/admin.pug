extends ../layout/admin

block contenido
  //- Valores seguros para que la vista tambien funcione si no hay resultados.
  - const totalPropiedades = resumen && resumen.total ? resumen.total : 0
  - const totalPublicadas = resumen && resumen.publicadas ? resumen.publicadas : 0
  - const totalPendientes = resumen && resumen.pendientes ? resumen.pendientes : 0
  - const mensajesResumen = resumen && resumen.mensajes ? resumen.mensajes : { recibidos: 0, leidos: 0, pendientes: 0 }
  - const totalListado = paginacion && paginacion.totalResultados ? paginacion.totalResultados : 0
  - const paginaActual = paginacion && paginacion.paginaActual ? paginacion.paginaActual : 1
  - const totalPaginas = paginacion && paginacion.paginas ? paginacion.paginas : 0
  - const rangoPaginas = paginacion && paginacion.rango ? paginacion.rango : []
  - const estadoQuery = filtro === "pendientes" ? "&estado=pendientes" : ""

  //- Panel principal de propiedades del usuario autenticado.
  section(class="space-y-8")
    header(class="flex flex-col gap-5 border-b border-slate-200 pb-7 sm:flex-row sm:items-end sm:justify-between")
      div(class="min-w-0")
        p(class="text-sm font-bold uppercase text-emerald-700") Panel privado
        h1(class="mt-2 break-words text-3xl font-extrabold text-slate-900 sm:text-4xl")= pagina
        if usuario
          p(class="mt-2 max-w-2xl text-sm leading-6 text-slate-600 sm:text-base") Hola #{usuario.nombre}, administra tus publicaciones y completa los anuncios pendientes.
        else
          p(class="mt-2 max-w-2xl text-sm leading-6 text-slate-600 sm:text-base") Administra tus publicaciones y completa los anuncios pendientes.

      //- La accion principal utiliza un boton solido.
      a(
        class="inline-flex min-h-11 shrink-0 items-center justify-center rounded-full bg-emerald-600 px-5 py-3 text-sm font-bold text-white shadow-sm transition hover:bg-emerald-700 focus:outline-none focus:ring-4 focus:ring-emerald-200"
        href="/propiedades/crear"
      ) Publicar propiedad

    //- Indicadores calculados con las propiedades reales del usuario.
    section(
      class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4"
      aria-label="Resumen de propiedades"
    )
      article(class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm")
        p(class="text-sm font-semibold text-slate-500") Publicadas
        p(
          class="mt-2 text-3xl font-extrabold text-emerald-700"
          data-total-publicadas
        )= totalPublicadas

      article(class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm")
        a(
          class="block rounded-md outline-none transition hover:bg-amber-50 focus:ring-4 focus:ring-amber-100"
          href="/mis-propiedades?estado=pendientes#listado-propiedades"
          aria-label=`Ver ${totalPendientes} propiedades pendientes de imagen`
        )
          p(class="text-sm font-semibold text-slate-500") Pendientes de imagen
          p(class="mt-2 text-3xl font-extrabold text-amber-600")= totalPendientes
          p(class="mt-2 text-xs font-bold text-amber-700") Ver propiedades

      article(class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm")
        p(class="text-sm font-semibold text-slate-500") Total
        p(class="mt-2 text-3xl font-extrabold text-slate-900")= totalPropiedades

      article(class="rounded-lg border border-emerald-200 bg-white p-5 shadow-sm")
        div(class="flex items-start justify-between gap-3")
          div
            p(class="text-sm font-semibold text-slate-500") Mensajes
            p(class="mt-2 text-3xl font-extrabold text-emerald-700")= mensajesResumen.recibidos
          if mensajesResumen.pendientes
            span(class="rounded-full bg-amber-100 px-2.5 py-1 text-xs font-bold text-amber-800") Nuevos
        dl(class="mt-4 grid grid-cols-2 divide-x divide-slate-200 border-t border-slate-100 pt-3")
          div(class="pr-3")
            dt(class="text-xs font-semibold text-slate-500") Leídos
            dd(class="mt-1 text-lg font-extrabold text-slate-800")= mensajesResumen.leidos
          div(class="pl-3")
            dt(class="text-xs font-semibold text-slate-500") Pendientes
            dd(class="mt-1 text-lg font-extrabold text-amber-700")= mensajesResumen.pendientes

    section(class="space-y-5" aria-labelledby="listado-propiedades")
      div(class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between")
        div
          if filtro === "pendientes"
            h2#listado-propiedades(class="text-xl font-extrabold text-slate-900 sm:text-2xl") Pendientes de imagen
            p(class="mt-1 text-sm text-slate-600") Completa estas propiedades para poder publicarlas.
          else
            h2#listado-propiedades(class="text-xl font-extrabold text-slate-900 sm:text-2xl") Tus anuncios
            p(class="mt-1 text-sm text-slate-600") Las publicaciones más recientes aparecen primero.

        div(class="flex flex-wrap items-center gap-3")
          p(class="text-sm font-semibold text-slate-500")
            | #{totalListado} #{totalListado === 1 ? "propiedad" : "propiedades"}
          if filtro === "pendientes"
            a(
              class="inline-flex min-h-10 items-center justify-center rounded-full border border-emerald-600 px-4 py-2 text-sm font-bold text-emerald-700 transition hover:bg-emerald-50 focus:outline-none focus:ring-4 focus:ring-emerald-100"
              href="/mis-propiedades"
            ) Ver todas

      if errores && errores.length
        div(class="rounded-lg border border-red-200 bg-red-50 px-4 py-3" role="alert")
          each error in errores
            p(class="text-sm font-semibold text-red-700")= error.msg

      if mensaje
        div(
          class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 transition duration-500"
          role="status"
          data-mensaje-temporal
        )
          p(class="text-sm font-semibold text-emerald-800")= mensaje

      //- JavaScript anuncia aquí el resultado sin recargar la página.
      div(
        class="hidden rounded-lg border px-4 py-3 transition duration-500"
        role="status"
        aria-live="polite"
        data-estado-mensaje
      )

      if propiedades && propiedades.length
        ul(class="grid grid-cols-1 gap-5")
          each propiedad in propiedades
            //- La asociacion siempre entrega un arreglo, pero el valor seguro
            //- mantiene estable la vista durante errores o datos incompletos.
            - const totalMensajes = propiedad.mensajes ? propiedad.mensajes.length : 0
            - const mensajesSinLeer = propiedad.mensajes ? propiedad.mensajes.filter((mensaje) => !mensaje.leido).length : 0
            li(class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm transition hover:border-emerald-300 hover:shadow-md")
              article(class="grid min-w-0 md:grid-cols-[15rem_minmax(0,1fr)] xl:grid-cols-[17rem_minmax(0,1fr)_auto]")
                //- La imagen mantiene una proporcion estable en cada pantalla.
                div(class="aspect-[16/10] overflow-hidden bg-slate-100 md:aspect-auto md:min-h-64")
                  if propiedad.imagen
                    img(
                      class="h-full w-full object-cover"
                      src=`/uploads/${propiedad.imagen}`
                      alt=`Imagen de ${propiedad.titulo}`
                      loading="lazy"
                    )
                  else
                    div(class="flex h-full min-h-52 items-center justify-center px-6 text-center md:min-h-64")
                      div
                        p(class="text-sm font-bold text-slate-600") Imagen pendiente
                        p(class="mt-1 text-xs leading-5 text-slate-500") Completa el anuncio para publicarlo.

                div(class="min-w-0 p-5 sm:p-6")
                  div(class="flex flex-wrap items-start justify-between gap-3")
                    div(class="min-w-0")
                      p(class="text-sm font-bold text-emerald-700")= propiedad.categoria && propiedad.categoria.nombre ? propiedad.categoria.nombre : "Sin categoría"
                      if propiedad.publicado
                        h3(
                          class="mt-1 break-words text-xl font-extrabold sm:text-2xl"
                          data-propiedad-titulo=propiedad.id
                        )
                          a(
                            class="text-slate-900 outline-none transition hover:text-emerald-700 focus:text-emerald-700 focus:underline"
                            href=`/propiedad/${propiedad.id}`
                          )= propiedad.titulo
                      else
                        h3(
                          class="mt-1 break-words text-xl font-extrabold text-slate-900 sm:text-2xl"
                          data-propiedad-titulo=propiedad.id
                        )= propiedad.titulo

                    if propiedad.publicado
                      span(
                        class="shrink-0 rounded-full border border-emerald-300 bg-emerald-50 px-3 py-1 text-xs font-bold text-emerald-700"
                        data-estado-indicador=propiedad.id
                      ) Publicada
                    else if propiedad.imagen
                      span(
                        class="shrink-0 rounded-full border border-amber-300 bg-amber-50 px-3 py-1 text-xs font-bold text-amber-700"
                        data-estado-indicador=propiedad.id
                      ) Pausada
                    else
                      span(
                        class="shrink-0 rounded-full border border-slate-300 bg-slate-50 px-3 py-1 text-xs font-bold text-slate-600"
                      ) Pendiente

                  p(class="mt-4 text-2xl font-extrabold text-slate-900")= propiedad.precio && propiedad.precio.precio ? propiedad.precio.precio : "Precio no disponible"

                  //- El enlace lleva a la futura bandeja de mensajes del anuncio.
                  a(
                    href=`/mensajes/${propiedad.id}`
                    class="mt-4 inline-flex min-h-10 items-center gap-2 rounded-full border border-emerald-600 px-4 py-2 text-sm font-bold text-emerald-700 outline-none transition hover:bg-emerald-50 hover:text-emerald-800 focus:ring-4 focus:ring-emerald-100"
                    aria-label=`Leer ${totalMensajes} ${totalMensajes === 1 ? "mensaje" : "mensajes"} de ${propiedad.titulo}`
                  )
                    span(
                      class="grid h-6 min-w-6 place-items-center rounded-full bg-emerald-100 px-1.5 text-xs text-emerald-800"
                      aria-hidden="true"
                    )= totalMensajes
                    span= totalMensajes === 1 ? "Mensaje" : "Mensajes"
                    if mensajesSinLeer
                      span(class="rounded-full bg-amber-100 px-2 py-0.5 text-xs text-amber-800") #{mensajesSinLeer} #{mensajesSinLeer === 1 ? "nuevo" : "nuevos"}

                  if propiedad.calle
                    p(class="mt-3 break-words text-sm leading-6 text-slate-600")= propiedad.calle

                  dl(class="mt-5 grid grid-cols-3 divide-x divide-slate-200 border-y border-slate-200 py-3")
                    div(class="px-2 text-center first:pl-0")
                      dt(class="text-xs font-semibold text-slate-500") Habitaciones
                      dd(class="mt-1 text-base font-extrabold text-slate-900")= propiedad.habitaciones
                    div(class="px-2 text-center")
                      dt(class="text-xs font-semibold text-slate-500") Estacionamiento
                      dd(class="mt-1 text-base font-extrabold text-slate-900")= propiedad.estacionamiento
                    div(class="px-2 text-center last:pr-0")
                      dt(class="text-xs font-semibold text-slate-500") WC
                      dd(class="mt-1 text-base font-extrabold text-slate-900")= propiedad.wc

                //- Acciones reales protegidas por autenticacion y token CSRF.
                div(class="grid content-center gap-3 border-t border-slate-200 p-5 md:col-start-2 sm:grid-cols-3 xl:col-start-auto xl:min-w-48 xl:grid-cols-1 xl:border-l xl:border-t-0 xl:p-6")
                  if !propiedad.imagen
                    a(
                      class="inline-flex min-h-11 w-full items-center justify-center rounded-full bg-emerald-600 px-5 py-3 text-center text-sm font-bold text-white transition hover:bg-emerald-700 focus:outline-none focus:ring-4 focus:ring-emerald-200"
                      href=`/propiedades/agregar-imagen/${propiedad.id}`
                    ) Agregar imagen
                  else
                    form(
                      method="POST"
                      action=`/propiedades/estado/${propiedad.id}`
                      data-cambiar-estado
                      data-propiedad-id=propiedad.id
                      data-publicado=propiedad.publicado ? "true" : "false"
                    )
                      input(type="hidden" name="_csrf" value=csrfToken)
                      button(
                        class=`min-h-11 w-full cursor-pointer rounded-full border px-5 py-3 text-sm font-bold transition focus:outline-none focus:ring-4 ${propiedad.publicado ? "border-amber-400 text-amber-700 hover:bg-amber-50 focus:ring-amber-100" : "border-emerald-500 text-emerald-700 hover:bg-emerald-50 focus:ring-emerald-100"}`
                        type="submit"
                        data-estado-boton
                      )= propiedad.publicado ? "Pausar anuncio" : "Publicar anuncio"

                  a(
                    class="inline-flex min-h-11 w-full items-center justify-center rounded-full border border-emerald-600 px-5 py-3 text-center text-sm font-bold text-emerald-700 transition hover:bg-emerald-50 focus:outline-none focus:ring-4 focus:ring-emerald-100"
                    href=`/propiedades/editar/${propiedad.id}`
                  ) Editar

                  form(
                    method="POST"
                    action=`/propiedades/eliminar/${propiedad.id}`
                    data-eliminar-propiedad
                  )
                    input(type="hidden" name="_csrf" value=csrfToken)
                    button(
                      class="min-h-11 w-full cursor-pointer rounded-full border border-red-300 px-5 py-3 text-sm font-bold text-red-700 transition hover:bg-red-50 focus:outline-none focus:ring-4 focus:ring-red-100"
                      type="submit"
                    ) Eliminar
        //- El paginador conserva el filtro activo y regresa al listado.
        if totalPaginas > 1
          nav(
            class="flex flex-col gap-4 border-t border-slate-200 pt-6 sm:flex-row sm:items-center sm:justify-between"
            aria-label="Paginación de propiedades"
          )
            p(class="text-center text-sm font-semibold text-slate-500 sm:text-left") Página #{paginaActual} de #{totalPaginas}

            div(class="flex flex-wrap items-center justify-center gap-2")
              if paginaActual > 1
                a(
                  class="inline-flex min-h-10 items-center justify-center rounded-full border border-slate-300 px-4 py-2 text-sm font-bold text-slate-700 transition hover:border-emerald-500 hover:bg-emerald-50 hover:text-emerald-700 focus:outline-none focus:ring-4 focus:ring-emerald-100"
                  href=`/mis-propiedades?pagina=${paginaActual - 1}${estadoQuery}#listado-propiedades`
                  rel="prev"
                ) Anterior

              each numero in rangoPaginas
                if numero === "..."
                  span(class="px-1 text-sm font-bold text-slate-400" aria-hidden="true") …
                else if numero === paginaActual
                  span(
                    class="grid h-10 min-w-10 place-items-center rounded-full bg-emerald-700 px-3 text-sm font-bold text-white"
                    aria-current="page"
                  )= numero
                else
                  a(
                    class="grid h-10 min-w-10 place-items-center rounded-full border border-slate-300 px-3 text-sm font-bold text-slate-700 transition hover:border-emerald-500 hover:bg-emerald-50 hover:text-emerald-700 focus:outline-none focus:ring-4 focus:ring-emerald-100"
                    href=`/mis-propiedades?pagina=${numero}${estadoQuery}#listado-propiedades`
                    aria-label=`Ir a la página ${numero}`
                  )= numero

              if paginaActual < totalPaginas
                a(
                  class="inline-flex min-h-10 items-center justify-center rounded-full border border-emerald-600 px-4 py-2 text-sm font-bold text-emerald-700 transition hover:bg-emerald-50 focus:outline-none focus:ring-4 focus:ring-emerald-100"
                  href=`/mis-propiedades?pagina=${paginaActual + 1}${estadoQuery}#listado-propiedades`
                  rel="next"
                ) Siguiente
      else
        //- Este estado se muestra solamente cuando no existen propiedades.
        div(class="rounded-lg border border-dashed border-slate-300 bg-white px-5 py-12 text-center sm:px-8")
          if filtro === "pendientes"
            h3(class="text-xl font-extrabold text-slate-900") No hay propiedades pendientes
            p(class="mx-auto mt-2 max-w-lg text-sm leading-6 text-slate-600") Todas tus propiedades tienen una imagen asignada.
            a(
              class="mt-6 inline-flex min-h-11 items-center justify-center rounded-full border border-emerald-600 px-5 py-3 text-sm font-bold text-emerald-700 transition hover:bg-emerald-50 focus:outline-none focus:ring-4 focus:ring-emerald-100"
              href="/mis-propiedades"
            ) Ver todas
          else
            h3(class="text-xl font-extrabold text-slate-900") Aún no tienes propiedades
            p(class="mx-auto mt-2 max-w-lg text-sm leading-6 text-slate-600") Publica tu primera propiedad y empieza a administrar tus anuncios desde este panel.
            a(
              class="mt-6 inline-flex min-h-11 items-center justify-center rounded-full bg-emerald-600 px-5 py-3 text-sm font-bold text-white transition hover:bg-emerald-700 focus:outline-none focus:ring-4 focus:ring-emerald-200"
              href="/propiedades/crear"
            ) Crear primera propiedad

block scripts
  script(src="/js/admin.js" defer)
  script(src="/js/cambiarEstado.js" defer)
