extends ../layout/admin

block contenido
  //- Bandeja privada de mensajes para una sola propiedad.
  section(class="space-y-7")
    header(class="flex flex-col gap-5 border-b border-slate-200 pb-7 sm:flex-row sm:items-end sm:justify-between")
      div(class="min-w-0")
        p(class="text-sm font-bold uppercase text-emerald-700") Consultas recibidas
        h1(class="mt-2 break-words text-3xl font-extrabold text-slate-900 sm:text-4xl")= pagina
        if propiedad
          p(class="mt-2 max-w-3xl break-words text-sm leading-6 text-slate-600 sm:text-base")
            | Mensajes relacionados con 
            strong(class="font-bold text-slate-800")= propiedad.titulo

      a(
        href="/mis-propiedades"
        class="inline-flex min-h-11 shrink-0 items-center justify-center rounded-full border border-emerald-600 px-5 py-3 text-sm font-bold text-emerald-700 transition hover:bg-emerald-50 hover:text-emerald-800 focus:outline-none focus:ring-4 focus:ring-emerald-100"
      ) Volver a mis propiedades

    if errores && errores.length
      div(class="rounded-lg border border-red-200 bg-red-50 px-4 py-3" role="alert")
        each error in errores
          p(class="text-sm font-semibold text-red-700")= error.msg

    if propiedad
      section(
        class="flex flex-col gap-4 rounded-lg border border-slate-200 bg-white p-4 shadow-sm sm:flex-row sm:items-center sm:p-5"
        aria-label="Propiedad seleccionada"
      )
        if propiedad.imagen
          img(
            class="h-24 w-full rounded-md object-cover sm:w-36"
            src=`/uploads/${propiedad.imagen}`
            alt=`Imagen de ${propiedad.titulo}`
          )
        else
          div(class="grid h-24 w-full place-items-center rounded-md bg-slate-100 px-4 text-center text-sm font-semibold text-slate-500 sm:w-36") Sin imagen

        div(class="min-w-0 flex-1")
          p(class="text-xs font-bold uppercase text-emerald-700") Propiedad
          h2(class="mt-1 break-words text-xl font-extrabold text-slate-900")= propiedad.titulo
          p(class="mt-2 text-sm font-semibold text-slate-500")
            | #{mensajes.length} #{mensajes.length === 1 ? "mensaje recibido" : "mensajes recibidos"}

        a(
          href=`/propiedad/${propiedad.id}`
          class="inline-flex min-h-10 shrink-0 items-center justify-center rounded-full border border-slate-300 px-4 py-2 text-sm font-bold text-slate-700 transition hover:border-emerald-500 hover:bg-emerald-50 hover:text-emerald-700 focus:outline-none focus:ring-4 focus:ring-emerald-100"
        ) Ver anuncio

    if mensajes && mensajes.length
      ul(class="grid gap-4" aria-label="Mensajes recibidos")
        each mensaje in mensajes
          - const remitente = mensaje.usuario || {}
          - const fechaMensaje = new Intl.DateTimeFormat("es-MX", { dateStyle: "long", timeStyle: "short" }).format(new Date(mensaje.createdAt))
          li(
            id=`mensaje-${mensaje.id}`
            class=mensaje.leido ? "rounded-lg border border-slate-200 bg-white p-5 shadow-sm transition hover:border-emerald-300 hover:shadow-md sm:p-6" : "rounded-lg border border-amber-300 bg-amber-50/40 p-5 shadow-sm transition hover:border-amber-400 hover:shadow-md sm:p-6"
          )
            article(class="space-y-5")
              header(class="flex flex-col gap-3 border-b border-slate-100 pb-4 sm:flex-row sm:items-start sm:justify-between")
                div(class="min-w-0")
                  div(class="flex flex-wrap items-center gap-2")
                    p(class="break-words text-lg font-extrabold text-slate-900")= remitente.nombre || "Usuario"
                    if mensaje.leido
                      span(class="rounded-full border border-slate-300 bg-slate-50 px-2.5 py-1 text-xs font-bold text-slate-600") Leído
                    else
                      span(class="rounded-full border border-amber-300 bg-amber-100 px-2.5 py-1 text-xs font-bold text-amber-800") Nuevo
                  if remitente.email
                    a(
                      href=`mailto:${remitente.email}`
                      class="mt-1 inline-block break-all text-sm font-semibold text-emerald-700 outline-none transition hover:text-emerald-800 hover:underline focus:underline"
                    )= remitente.email
                time(
                  class="shrink-0 text-xs font-semibold text-slate-500 sm:text-right"
                  datetime=new Date(mensaje.createdAt).toISOString()
                )= fechaMensaje

              p(class="whitespace-pre-line break-words text-sm leading-7 text-slate-700 sm:text-base")= mensaje.mensaje

              div(class="flex flex-col gap-2 sm:flex-row sm:justify-end")
                if !mensaje.leido
                  form(method="POST" action=`/mensajes/${mensaje.id}/leido`)
                    input(type="hidden" name="_csrf" value=csrfToken)
                    button(
                      type="submit"
                      class="inline-flex min-h-10 w-full cursor-pointer items-center justify-center rounded-full border border-emerald-600 px-4 py-2 text-sm font-bold text-emerald-700 transition hover:bg-emerald-50 focus:outline-none focus:ring-4 focus:ring-emerald-100 sm:w-auto"
                    ) Marcar como leído
                if remitente.email
                  a(
                    href=`mailto:${remitente.email}?subject=${encodeURIComponent(`Consulta sobre ${propiedad.titulo}`)}`
                    class="inline-flex min-h-10 items-center justify-center rounded-full bg-emerald-600 px-4 py-2 text-sm font-bold text-white transition hover:bg-emerald-700 focus:outline-none focus:ring-4 focus:ring-emerald-200"
                  ) Responder por correo
    else if !errores || !errores.length
      section(class="rounded-lg border border-dashed border-slate-300 bg-white px-5 py-12 text-center sm:px-8")
        p(class="text-sm font-bold uppercase text-emerald-700") Bandeja vacía
        h2(class="mt-2 text-2xl font-extrabold text-slate-900") Todavía no hay mensajes
        p(class="mx-auto mt-3 max-w-xl text-sm leading-6 text-slate-600") Cuando un usuario se interese en esta propiedad, sus consultas aparecerán aquí.
        a(
          href="/mis-propiedades"
          class="mt-6 inline-flex min-h-11 items-center justify-center rounded-full bg-emerald-600 px-5 py-3 text-sm font-bold text-white transition hover:bg-emerald-700 focus:outline-none focus:ring-4 focus:ring-emerald-200"
        ) Regresar al panel
