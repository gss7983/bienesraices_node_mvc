extends ../layout/admin

block contenido
  //- Segunda etapa del registro de una propiedad.
  //- Dropzone envia la imagen y Multer la almacena en public/uploads.
  section(class="space-y-8")
    div(class="flex flex-col gap-4 border-b border-slate-200 pb-6 lg:flex-row lg:items-end lg:justify-between")
      div
        p(class="text-sm font-semibold uppercase tracking-[0.25em] text-emerald-700") Publicacion creada
        h1(class="mt-3 text-3xl font-black text-slate-900 sm:text-4xl")= pagina
        p(class="mt-3 max-w-2xl text-sm leading-6 text-slate-500") Agrega la imagen principal para completar la publicacion de #{propiedad.titulo}.

      a(class="inline-flex items-center justify-center rounded-full border border-emerald-700 px-6 py-3 text-sm font-black uppercase tracking-wide text-emerald-700 transition hover:border-emerald-800 hover:bg-emerald-50 hover:text-emerald-800 focus:outline-none focus:ring-4 focus:ring-emerald-100" href="/mis-propiedades") Volver al Panel

    div(class="mx-auto max-w-4xl overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm")
      div(class="border-b border-slate-200 px-5 py-5 sm:px-8")
        h2(class="text-lg font-black text-slate-900")= propiedad.titulo
        p(class="mt-1 text-sm leading-6 text-slate-500") Selecciona una imagen principal para completar la publicacion.

      div(class="px-5 py-8 sm:px-8")
        //- Dropzone convierte este formulario en una zona para seleccionar y previsualizar.
        form#agregar-imagen(
          class="dropzone min-h-64 rounded-2xl border-2 border-dashed border-emerald-200 bg-emerald-50/50 px-6 py-12 text-center transition hover:border-emerald-400 hover:bg-emerald-50"
          action=`/propiedades/agregar-imagen/${propiedad.id}`
          method="POST"
          enctype="multipart/form-data"
        )
          input(type="hidden" name="_csrf" value=csrfToken)
          input(type="hidden" name="propiedadId" value=propiedad.id)

          div.dz-message
            div(class="mx-auto grid h-14 w-14 place-items-center rounded-full bg-emerald-100 text-2xl font-black text-emerald-700") +
            h3(class="mt-5 text-lg font-black text-slate-900") Selecciona la imagen principal
            p(class="mx-auto mt-2 max-w-md text-sm leading-6 text-slate-500") Arrastra una imagen hasta aqui o haz clic para seleccionarla.
            p(class="mt-2 text-xs font-semibold uppercase tracking-wide text-slate-400") JPG, JPEG, PNG o WebP

        //- El boton procesa la cola de Dropzone y publica la propiedad.
        div(class="mt-8 flex justify-end border-t border-slate-100 pt-6")
          button#publicar-propiedad(
            class="inline-flex w-full cursor-not-allowed items-center justify-center rounded-full bg-slate-300 px-6 py-3 text-sm font-black uppercase tracking-wide text-slate-500 shadow-sm sm:w-auto"
            type="button"
            disabled
          ) Publicar Propiedad

block styles
  link(rel="stylesheet" href="https://unpkg.com/dropzone@5.9.3/dist/min/dropzone.min.css")

block scripts
  script(src="/js/agregarImagen.js" defer)
