extends ../layout/index

block contenido
  //- Contenedor principal para definir un nuevo password.
  //- Mantiene el estilo de las vistas de autenticacion existentes.
  section(class="min-h-[calc(100vh-5rem)] grid place-items-center")
    div(class="w-full max-w-5xl overflow-hidden rounded-2xl bg-white shadow-2xl shadow-gray-200 ring-1 ring-gray-100 lg:grid lg:grid-cols-2")
      //- Panel visual izquierdo: explica que el enlace ya fue validado.
      div(class="hidden bg-gradient-to-br from-slate-900 via-teal-800 to-emerald-700 p-10 text-white lg:flex lg:flex-col lg:justify-between")
        div
          //- Logo tipografico: "Bienes" fuerte y "Raices" ligero, sin espacio entre palabras.
          a(class="inline-block border-b border-emerald-200/40 pb-1 text-2xl uppercase tracking-wide text-white" href="/auth/login")
            strong(class="font-extrabold") Bienes
            span(class="font-normal") Raices
          h1(class="mt-6 text-4xl font-black leading-tight") Crea un password nuevo.
          p(class="mt-5 max-w-md text-base leading-7 text-emerald-50") El enlace fue validado. Escribe un password seguro para recuperar el acceso a tu cuenta.

        div(class="rounded-2xl bg-white/10 p-5 backdrop-blur")
          p(class="text-sm font-semibold uppercase tracking-wide text-emerald-100") Recomendacion
          p(class="mt-3 text-2xl font-black") Usa al menos 8 caracteres.
          p(class="mt-3 text-sm leading-6 text-emerald-50") Combina letras, numeros y simbolos para mejorar la seguridad de tu cuenta.

      //- Panel derecho: formulario para guardar el nuevo password.
      div(class="px-6 py-10 sm:px-10 lg:px-12")
        div(class="mx-auto w-full max-w-md")
          p(class="text-sm font-semibold uppercase tracking-[0.25em] text-emerald-700") Nuevo acceso
          h2(class="mt-3 text-3xl font-black text-slate-900")= pagina
          p(class="mt-3 text-sm leading-6 text-slate-500") Escribe tu nuevo password para poder iniciar sesion nuevamente.

          //- Mostramos errores de validacion enviados desde el controlador.
          if errores && errores.length
            div(class="mt-6 space-y-2")
              each error in errores
                p(class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm font-bold text-red-700")= error.msg

          form(class="mt-8 space-y-5" method="POST" action=`/auth/olvide-password/${token}` novalidate)
            input(type="hidden" name="_csrf" value=csrfToken)
            div
              label(class="mb-2 block text-sm font-bold text-slate-700" for="password") Nuevo password
              input#password(class="w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-emerald-600 focus:ring-4 focus:ring-emerald-100" type="password" name="password" placeholder="Tu Nuevo Password")

            input(class="w-full cursor-pointer rounded-full bg-emerald-700 px-6 py-3 text-sm font-black uppercase tracking-wide text-white shadow-sm transition hover:bg-emerald-800 hover:shadow-md focus:outline-none focus:ring-4 focus:ring-emerald-200" type="submit" value="Guardar Password")

          nav(class="mt-6 flex flex-col gap-3 text-sm sm:flex-row sm:items-center sm:justify-between")
            a(class="inline-flex items-center justify-center rounded-full border border-emerald-700 px-4 py-2 font-bold text-emerald-700 transition hover:bg-emerald-50 hover:text-emerald-800 focus:outline-none focus:ring-4 focus:ring-emerald-100" href="/auth/login") Ya tengo cuenta
            a(class="inline-flex items-center justify-center rounded-full border border-emerald-700 px-4 py-2 font-bold text-emerald-700 transition hover:bg-emerald-50 hover:text-emerald-800 focus:outline-none focus:ring-4 focus:ring-emerald-100" href="/auth/registro") Crear cuenta
